{
  "name": "bladeacer-docs",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint:css": "stylelint --fix 'src/styles/**/*.scss'",
    "lint:ts": "eslint 'src/scripts/**/*.ts'",
    "lint": "pnpm run lint:css && pnpm run lint:ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "format:check": "prettier --check 'src/**/*.{astro,ts,css,scss}'",
    "format": "prettier --write 'src/**/*.{astro,ts,css,scss}'"
  },
  "dependencies": {
    "@astrojs/rss": "4.0.18",
    "@iconify-json/simple-icons": "^1.2.80",
    "@lucide/astro": "1.14.0",
    "@rwh/keystrokes": "^1.5.6",
    "astro": "6.4.2",
    "astro-icon": "^1.1.5",
    "flexsearch": "^0.8.212",
    "lucide": "^1.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "sass": "^1.101.0",
    "stylelint": "^17.13.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-high-performance-animation": "^2.0.0",
    "stylelint-no-unsupported-browser-features": "^8.1.1",
    "stylelint-plugin-defensive-css": "^2.9.3",
    "stylelint-prettier": "^5.0.3",
    "stylelint-use-logical": "^2.1.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9"
  }
}
