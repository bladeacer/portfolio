---
import BaseLayout from "../layouts/BaseLayout.astro";
import { 
  Github, Gitlab, Rss, Codeberg, Gmail,
  Html5, Css, Sass, Bootstrap, Figma, Javascript, 
  React, Nodedotjs, Postman, Python, Kotlin, Dotnet,
  Gnubash, Mysql, Sqlite, Sequelize, Docker 
} from 'simple-icons-astro';
import User from '@lucide/astro/icons/user';
import Network from '@lucide/astro/icons/network';
import CodeXML from '@lucide/astro/icons/code-xml';
import Download from '@lucide/astro/icons/download';
import Keyboard from '@lucide/astro/icons/keyboard';
import { Image } from 'astro:assets';
const pageTitle = "About Me";
---

<BaseLayout pageTitle={pageTitle}>
  <div class="profile">
    <Image alt="Profile Picture" src="/portfolio/profile.png" width="128" height="128"/>
    <div class="profile-desc">
      <p>
        Hi there, I write software I use.
      </p>
      <ul>
        <li>
          css, <a target="_blank" href="/portfolio/posts/vim">vim</a>, linux enjoyer
        </li>
        <li>
          currently a student
        </li>
        <li>
          software developer in the making
        </li>
      </ul>
      <p>
        UTC+8 / EN / zh-CN
      </p>
      <br>
      <a href="/portfolio/resume" target="_blank">
        <p class="foot cta">
          <Download/>
            Download Resume/CV
        </p>
      </a>
      <a href="/portfolio/about#shortcuts" target="_blank">
        <p class="foot cta2">
          <Keyboard/>
            Shortcuts
        </p>
      </a>
      <a href="/portfolio/rss.xml" target="_blank">
        <p class="foot cta3">
          <Rss/>
            RSS Feed
        </p>
      </a>
    </div>
  </div>

  <h2>Current Works</h2>

  <div class="cards">
    <div class="card-item">
      <a target="_blank" href="https://github.com/bladeacer/flexcyon">
        <img src="/portfolio/dark_thumb.webp"/>
      </a>
      <p>
        flexcyon is a reasonably opinionated Obsidian.md theme. About <a target="_blank" href="/portfolio/posts/flexcyon">my thought process</a> while developing it.
      </p>
    </div>

    <div class="card-item">
      <a target="_blank" href="https://github.com/bladeacer/pdf-fmt">
        <img src="/portfolio/pdf-fmt-preview.png"/>
      </a>
      <p>
        <a target="_blank" href="https://github.com/bladeacer/pdf-fmt">pdf-fmt</a> is a PDF text extractor, processor and formatter.
        About <a target="_blank" href="/portfolio/posts/pdf-fmt">my thought process</a> while developing it.
      </p>
    </div>
    <div class="card-item">
      <a target="_blank" href="https://github.com/bladeacer/mnemosync">
        <img src="/portfolio/mmsync-preview.png"/>
      </a>
      <p>
        <a target="_blank" href="https://github.com/bladeacer/mnemosync">mnemosync</a> is a Golang CLI tool that lets you add folders to backup manually to a target Git repository. 
      </p>
    </div>
  </div>

  <h2>Tech Stack</h2>

  <div class="profile-2">
    <div>
      <h3>Frontend</h3>
      <p class="skill-icons">
        <a target="_blank" href="https://developer.mozilla.org/en-US/docs/Web/HTML">
          <Html5/>
        </a>
        <a target="_blank" href="https://developer.mozilla.org/en-US/docs/Web/CSS">
          <Css/>
        </a>
        <a target="_blank" href="https://sass-lang.com">
          <Sass/>
        </a>
        <a target="_blank" href="https://getbootstrap.com">
          <Bootstrap/>
        </a>
        <a target="_blank" href="https://www.figma.com">
          <Figma/>
        </a>
        <a target="_blank" href="https://developer.mozilla.org/en-US/docs/Web/JavaScript">
          <Javascript/>
        </a>
        <a target="_blank" href="https://react.dev">
          <React/>
        </a>
        <a target="_blank" href="https://nodejs.org/en">
          <Nodedotjs/>
        </a>
        <a target="_blank" href="https://www.postman.com/">
          <Postman/>
        </a>
      </p>
    </div>

    <div>
      <h3>Languages</h3>
      <p class="skill-icons">
        <a target="_blank" href="https://www.python.org/">
          <Python/>
        </a>
        <a target="_blank" href="https://kotlinlang.org/">
          <Kotlin/>
        </a>
        <a target="_blank" href="https://dotnet.microsoft.com/en-us/languages/csharp">
          <Dotnet/>
        </a>
        <a target="_blank" href="https://www.gnu.org/software/bash/">
          <Gnubash/>
        </a>
      </p>
    </div>

    <div>
      <h3>Databases</h3>
        <p class="skill-icons">
        <a target="_blank" href="https://www.mysql.com/">
          <Mysql/>
        </a>
        <a target="_blank" href="https://sqlite.org/">
          <Sqlite/>
        </a>
        <a target="_blank" href="https://sequelize.org/">
          <Sequelize/>
        </a>
      </p>
    </div>
  </div>

  <h2>Find me on</h2>
  <p>Feel free to connect or reach out to me via these channels.</p>
  <div class="profile-3">
    <p class="foot">
      <Gmail/>
      <a target="_blank" href="mailto:wg.nick.exe@gmail.com" target="_blank">Email</a>
    </p>
    <p class="foot">
      <Network/>
      <a target="_blank" href="https://www.linkedin.com/in/nicholas-wen-a525832b2/" target="_blank">LinkedIn</a>
    </p>
    <p class="foot">
      <User/>
      <a target="_blank" href="https://gravatar.com/objectoriginal8f1e7ecf6f" target="_blank">Gravatar</a>
    </p>
    <p class="foot">
      <Github/>
      <a target="_blank" href="https://github.com/bladeacer" target="_blank">GitHub</a>
    </p>
    <p class="foot">
      <Gitlab/>
      <a target="_blank" href="https://gitlab.com/bladeacer" target="_blank">GitLab</a>
    </p>
    <p class="foot">
      <Codeberg/>
      <a target="_blank" href="https://codeberg.org/bladeacer" target="_blank">Codeberg</a>
    </p>
  </div>
</BaseLayout>
