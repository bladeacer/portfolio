---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Popup from "../components/Popup.astro";
import "../styles/global.css";
const { pageTitle } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/portfolio/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/portfolio/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/portfolio/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="bladeacer's Portfolio" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="icon" type="image/png" href="/portfolio/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/portfolio/favicon.svg" />
    <link rel="shortcut icon" href="/portfolio/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/portfolio/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="bladeacer's Portfolio" />
    <link rel="manifest" href="/portfolio/site.webmanifest" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <style is:global>
      /* Status + Mode indicators side by side */
      .status-bar {
        position: fixed;
        bottom: 1rem;
        right: 1rem;
        z-index: 99999;
        display: flex;
        gap: 0.5rem;
        align-items: stretch;
      }
      .key-status {
        background: var(--flexcyon-base-02);
        border: 1px solid var(--flexcyon-base-04);
        border-radius: 8px;
        padding: 0.5rem 0.75rem;
        font-size: 0.85rem;
        color: var(--text-normal);
        font-family: "DepartureMono", "Maple Mono Medium", ui-monospace, monospace;
        max-width: 300px;
        line-height: 1.4;
      }
      .mode-indicator {
        background: var(--flexcyon-base-02);
        border: 1px solid var(--flexcyon-base-04);
        border-radius: 8px;
        padding: 0.5rem 0.75rem;
        font-size: 0.85rem;
        font-family: "DepartureMono", "Maple Mono Medium", ui-monospace, monospace;
        line-height: 1.4;
        color: var(--flexcyon-cyan);
        font-weight: bold;
        min-width: 3em;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      /* Search overlay - exact popup pattern */
      .search-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        max-width: none;
        z-index: 99999;
        display: none;
        background-color: color-mix(in oklch, var(--flexcyon-bg-col) 60%, transparent 40%);
      }
      .search-overlay.is-active {
        display: block;
      }
      .search-box {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: var(--flexcyon-base-02);
        border: 1px solid var(--flexcyon-base-04);
        border-radius: 12px;
        width: 90vw;
        max-width: 800px;
        max-height: 80vh;
        display: flex;
        flex-direction: column;
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
      }
      .search-input {
        width: 100%;
        border: none;
        background: transparent;
        color: var(--text-normal);
        font-family: "DepartureMono", "Maple Mono Medium", ui-monospace, monospace;
        font-size: 1rem;
        padding: 0.75rem 1.25rem;
        outline: none;
        border-bottom: 1px solid var(--flexcyon-base-04);
        box-sizing: border-box;
      }
      .search-input:focus {
        border-bottom-color: var(--flexcyon-blue);
      }
      .search-results {
        list-style: none;
        margin: 0;
        padding: 0;
        overflow-y: auto;
        flex: 1;
        max-width: unset;
      }
      .search-result-item {
        padding: 0.6rem 1.25rem;
        cursor: pointer;
        font-size: 0.9rem;
        color: var(--text-normal);
      }
      .search-result-item:hover, .search-selected {
        background-color: color-mix(in oklch, var(--flexcyon-cyan) 35%, var(--flexcyon-base-02)) !important;
        outline: 1px solid var(--flexcyon-cyan);
        outline-offset: -1px;
        border-radius: 4px;
      }
      .search-result-item a {
        color: var(--flexcyon-blue);
        text-decoration: none;
        width: 100%;
        display: block;
        max-width: unset;
      }
      .search-result-item:first-child {
        border-top: none;
      }
      .search-no-results {
        display: none;
        padding: 1rem;
        text-align: center;
        color: var(--text-faint);
        font-style: italic;
      }
      .search-highlight {
        background-color: var(--flexcyon-yellow);
        color: var(--flexcyon-base-01);
        padding: 0 2px;
        border-radius: 2px;
      }
      .search-snippet {
        font-size: 0.78rem;
        color: var(--text-faint);
        margin-top: 2px;
        line-height: 1.3;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        max-width: unset;
      }
      /* Command mode overlay - exact popup pattern */
      .command-mode-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        max-width: none;
        z-index: 99999;
        display: none;
        background-color: color-mix(in oklch, var(--flexcyon-bg-col) 60%, transparent 40%);
      }
      .command-mode-overlay.is-active {
        display: block;
      }
      .command-mode-box {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: var(--flexcyon-base-02);
        border: 1px solid var(--flexcyon-base-04);
        border-radius: 12px;
        width: 90vw;
        max-width: 800px;
        max-height: 80vh;
        display: flex;
        flex-direction: column;
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        pointer-events: auto;
      }
      .command-mode-input {
        width: 100%;
        border: none;
        background: transparent;
        color: var(--text-normal);
        font-family: "DepartureMono", "Maple Mono Medium", ui-monospace, monospace;
        font-size: 0.95rem;
        padding: 0.75rem 1.25rem;
        outline: none;
        border-bottom: 1px solid var(--flexcyon-base-04);
        box-sizing: border-box;
      }
      .command-mode-input:focus {
        border-bottom-color: var(--flexcyon-blue);
      }
      .command-mode-list {
        list-style: none;
        margin: 0;
        padding: 0;
        overflow-y: auto;
        max-height: 35vh;
      }
      .cm-item {
        padding: 0.5rem 1.25rem;
        cursor: pointer;
        font-size: 0.85rem;
        color: var(--text-normal);
        display: flex;
        align-items: center;
        border-bottom: 1px solid var(--flexcyon-base-03);
      }
      .cm-item:last-child {
        border-bottom: none;
      }
      .cm-item:hover, .cm-selected {
        background-color: color-mix(in oklch, var(--flexcyon-cyan) 35%, var(--flexcyon-base-02)) !important;
        outline: 1px solid var(--flexcyon-cyan);
        outline-offset: -1px;
        border-radius: 4px;
      }
      .cm-chord {
        font-family: "DepartureMono", "Maple Mono Medium", ui-monospace, monospace;
        color: var(--flexcyon-cyan);
        min-width: 4em;
        font-size: 0.85rem;
      }
      .cm-desc {
        color: var(--text-normal);
        font-size: 0.85rem;
      }
      .cm-empty {
        padding: 0.75rem;
        text-align: center;
        color: var(--text-faint);
        font-style: italic;
        font-size: 0.85rem;
      }
    </style>
  </head>
  <body>
    <div class="content-wrapper">
      <Header />
      <h1>{pageTitle}</h1>
      <slot />
      <Footer />
    </div>
    <Popup />

    <div class="status-bar">
      <div id="key-status" class="key-status" style="display:none">
        <span id="key-status-chord"></span><span id="key-status-desc"></span>
      </div>
      <div id="mode-indicator" class="mode-indicator">NOR</div>
    </div>

    <!-- Search overlay -->
    <div id="search-overlay" class="search-overlay">
      <div class="search-box">
        <input id="search-input" class="search-input" type="text" placeholder="Search pages..." autocomplete="off" spellcheck="false" />
        <div id="search-no-results" class="search-no-results">No results found.</div>
        <ul id="search-results" class="search-results"></ul>
      </div>
    </div>

    <!-- Command mode overlay (centered) -->
    <div id="command-mode-overlay" class="command-mode-overlay">
      <div class="command-mode-box">
        <input id="command-mode-input" class="command-mode-input" type="text" placeholder=":" autocomplete="off" spellcheck="false" />
        <ul id="command-mode-list" class="command-mode-list"></ul>
      </div>
    </div>

    <noscript>
      This site uses JavaScript functionality. Please ensure that JavaScript is enabled to continue.
      <br>
      Try reloading the page.
    </noscript>
    <script>
      import "../scripts/menu.js";
      import "../scripts/mousetrap.min.js";
      import "../scripts/settings-init.js";
      import "../scripts/status-indicator.js";
      import "../scripts/shortcuts-data.js";
      import "../scripts/vimlike.js";
      import "../scripts/shortcuts.js";
      import "../scripts/command-mode.js";
      import "../scripts/search.js";
    </script>
  </body>
</html>
