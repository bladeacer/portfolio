---
import "../styles/_popup.scss";
---
<div id="shortcuts-popup-overlay" class="popup-overlay">
  <div id="shortcuts-popup" class="popup-content" role="dialog" aria-modal="true" aria-label="Keyboard Shortcuts">
    <div class="popup-header">
      <h2 id="popup-title">Keyboard Shortcuts</h2>
      <button id="popup-close" class="popup-close" aria-label="Close">&times;</button>
    </div>
    <div class="popup-body">
      <p class="popup-top-link">
        <a href="/portfolio/about#shortcuts">View full shortcuts reference &rarr;</a>
      </p>
      <h4>Scrolling</h4>
      <table>
        <thead>
          <tr><th>Trigger</th><th>Action</th></tr>
        </thead>
        <tbody>
          <tr><td>j</td><td>Scroll down</td></tr>
          <tr><td>k</td><td>Scroll up</td></tr>
          <tr><td>&#123;</td><td>Previous heading</td></tr>
          <tr><td>&#125;</td><td>Next heading</td></tr>
          <tr><td>gg</td><td>Top of page</td></tr>
          <tr><td>G</td><td>Bottom of page</td></tr>
        </tbody>
      </table>
      <h4>Yanking</h4>
      <table>
        <thead>
          <tr><th>Trigger</th><th>Action</th></tr>
        </thead>
        <tbody>
          <tr><td>yy</td><td>Yank current element</td></tr>
          <tr><td>Y</td><td>Yank entire page</td></tr>
          <tr><td>y&#125;</td><td>Yank to next heading</td></tr>
          <tr><td>y&#123;</td><td>Yank to previous heading</td></tr>
          <tr><td>Nyy</td><td>Yank N elements (2yy = 2 lines)</td></tr>
        </tbody>
      </table>
      <h4>Navigation</h4>
      <table>
        <thead>
          <tr><th>Trigger</th><th>Action</th></tr>
        </thead>
        <tbody>
          <tr><td>Enter</td><td>Open link under active line</td></tr>
          <tr><td>h</td><td>Home page</td></tr>
          <tr><td>a</td><td>About page</td></tr>
          <tr><td>d</td><td>Digital garden</td></tr>
          <tr><td>c</td><td>Credits page</td></tr>
          <tr><td>#</td><td>Tags page</td></tr>
          <tr><td>s</td><td>Settings page</td></tr>
          <tr><td>ctrl+,</td><td>Settings page</td></tr>
          <tr><td>r</td><td>Resume</td></tr>
          <tr><td>!</td><td>RSS feed</td></tr>
          <tr><td>em</td><td>Email</td></tr>
          <tr><td>li</td><td>LinkedIn</td></tr>
          <tr><td>gh</td><td>GitHub</td></tr>
          <tr><td>gl</td><td>GitLab</td></tr>
          <tr><td>b</td><td>Codeberg</td></tr>
          <tr><td>gr</td><td>Gravatar</td></tr>
          <tr><td>&lt;</td><td>History back</td></tr>
          <tr><td>&gt;</td><td>History forward</td></tr>
        </tbody>
      </table>
      <h4>Toggles &amp; Modes</h4>
      <table>
        <thead>
          <tr><th>Trigger</th><th>Action</th></tr>
        </thead>
        <tbody>
          <tr><td>l</td><td>Highlight active line</td></tr>
          <tr><td>t</td><td>Toggle theme</td></tr>
          <tr><td>o</td><td>Toggle table of contents</td></tr>
          <tr><td>f</td><td>Open search</td></tr>
          <tr><td>:</td><td>Command palette</td></tr>
          <tr><td>ctrl+p</td><td>Command palette</td></tr>
          <tr><td>Alt+n</td><td>Next search result</td></tr>
          <tr><td>Alt+p</td><td>Previous search result</td></tr>
          <tr><td>?</td><td>Show shortcuts</td></tr>
          <tr><td>Esc</td><td>Close / Cancel</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    var overlay = document.getElementById("shortcuts-popup-overlay");
    if (!overlay) return;

    function close() { overlay.classList.remove("is-active"); }
    function open() { overlay.classList.add("is-active"); }

    window.toggleShortcutsPopup = function() {
      if (!overlay.classList.contains("is-active")) {
        open();
      } else {
        close();
      }
    };

    document.addEventListener("DOMContentLoaded", function() {
      document.getElementById("popup-close")?.addEventListener("click", close);

      overlay.addEventListener("click", function(e) {
        if (e.target === overlay) close();
      });

      document.addEventListener("keydown", function(e) {
        if (e.key === "Escape" && overlay.classList.contains("is-active")) close();
      });
    });
  })();
</script>
